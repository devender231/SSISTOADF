{
	"name": "Manual_DF_CLIENT_BRONZE_TO_SILVER",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "DS_SOURCE_CRM_CLIENT",
						"type": "DatasetReference"
					},
					"name": "CRMClientSource"
				},
				{
					"dataset": {
						"referenceName": "DS_SOURCE_RESEARCH_SUBSCRIPTION",
						"type": "DatasetReference"
					},
					"name": "ResearchSubscriptionSource"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "DS_TARGET_CLIENT",
						"type": "DatasetReference"
					},
					"name": "TargetClient"
				},
				{
					"dataset": {
						"referenceName": "DS_ERROR_LOG",
						"type": "DatasetReference"
					},
					"name": "Error"
				}
			],
			"transformations": [
				{
					"name": "JoinSources"
				},
				{
					"name": "DerivedColumns"
				},
				{
					"name": "DataQualityChecks"
				},
				{
					"name": "ConditionalSplit"
				}
			],
			"scriptLines": [
				"source(output(",
				"          CRMClientID as integer,",
				"          ClientFullName as string,",
				"          IndustryCode as string,",
				"          HQCountry as string,",
				"          AnnualRevenueRange as string,",
				"          EmployeeRange as string,",
				"          RelationshipCategory as string,",
				"          AccountOwner as string,",
				"          ContractStart as date,",
				"          ContractEnd as date,",
				"          StatusFlag as string,",
				"          ModifiedOn as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> CRMClientSource",
				"source(output(",
				"          SubscriptionID as integer,",
				"          SubscriberName as string,",
				"          Sector as string,",
				"          Country as string,",
				"          LastActivityDate as date,",
				"          SubscriptionType as string,",
				"          CreatedOn as timestamp",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> ResearchSubscriptionSource",
				"CRMClientSource, ResearchSubscriptionSource join(ClientFullName == SubscriberName,",
				"     joinType:'left',",
				"     matchType:'exact',",
				"     ignoreSpaces: false,",
				"     broadcast: 'auto')~> JoinSources",
				"JoinSources derive(ClientName = ClientFullName,",
				"          IndustrySector = IndustryCode,",
				"          HeadquartersCountry = HQCountry,",
				"          RevenueRange = AnnualRevenueRange,",
				"          EmployeeCountRange = EmployeeRange,",
				"          RelationshipType = SubscriptionType,",
				"          AccountManager = AccountOwner,",
				"          ContractStartDate = ContractStart,",
				"          ContractEndDate = ContractEnd,",
				"          ClientStatus = iif(StatusFlag == 'A','Active','Inactive'),",
				"          LastEngagementDate = LastActivityDate,",
				"          CreatedDate = currentUTC(),",
				"          ModifiedDate = ModifiedOn) ~> DerivedColumns",
				"DerivedColumns derive(ValidationErrors = iif(isNull(ClientName) || length(trim(ClientName)) == 0, 'ClientName cannot be null; ', '') +\r",
				"iif(\r",
				"    toString(IndustrySector) != 'Technology' &&\r",
				"    toString(IndustrySector) != 'Healthcare' &&\r",
				"    toString(IndustrySector) != 'Finance' &&\r",
				"    toString(IndustrySector) != 'Manufacturing' &&\r",
				"    toString(IndustrySector) != 'Retail' &&\r",
				"    toString(IndustrySector) != 'Energy' &&\r",
				"    toString(IndustrySector) != 'Other',\r",
				"    'IndustrySector invalid; ',\r",
				"    ''\r",
				") +\r",
				"iif(!isNull(HeadquartersCountry) && length(trim(HeadquartersCountry)) != 2, 'HeadquartersCountry invalid; ', '') +\r",
				"iif(\r",
				"    toString(RevenueRange) != '<1M' &&\r",
				"    toString(RevenueRange) != '1M-10M' &&\r",
				"    toString(RevenueRange) != '10M-100M' &&\r",
				"    toString(RevenueRange) != '100M-1B' &&\r",
				"    toString(RevenueRange) != '>1B' &&\r",
				"    toString(RevenueRange) != 'Unknown',\r",
				"    'RevenueRange invalid; ',\r",
				"    ''\r",
				") +\r",
				"iif(\r",
				"    toString(EmployeeCountRange) != '1-10' &&\r",
				"    toString(EmployeeCountRange) != '11-50' &&\r",
				"    toString(EmployeeCountRange) != '51-200' &&\r",
				"    toString(EmployeeCountRange) != '201-1000' &&\r",
				"    toString(EmployeeCountRange) != '1001-5000' &&\r",
				"    toString(EmployeeCountRange) != '5000+' &&\r",
				"    toString(EmployeeCountRange) != 'Unknown',\r",
				"    'EmployeeCountRange invalid; ',\r",
				"    ''\r",
				") +\r",
				"iif(\r",
				"    toString(RelationshipType) != 'Premium' &&\r",
				"    toString(RelationshipType) != 'Standard' &&\r",
				"    toString(RelationshipType) != 'Basic' &&\r",
				"    toString(RelationshipType) != 'Trial',\r",
				"    'RelationshipType invalid; ',\r",
				"    ''\r",
				") +\r",
				"iif(isNull(ContractStartDate), 'ContractStartDate cannot be null; ', '') +\r",
				"iif(\r",
				"    !isNull(ContractEndDate) &&\r",
				"    !isNull(ContractStartDate) &&\r",
				"    toTimestamp(ContractEndDate) <= toTimestamp(ContractStartDate),\r",
				"    'ContractEndDate must be > ContractStartDate; ',\r",
				"    ''\r",
				")+\r",
				"iif(\r",
				"    toString(ClientStatus) != 'Active' &&\r",
				"    toString(ClientStatus) != 'Inactive',\r",
				"    'ClientStatus invalid; ',\r",
				"    ''\r",
				")) ~> DataQualityChecks",
				"DataQualityChecks split(length(trim(ValidationErrors)) == 0,",
				"     disjoint: false) ~> ConditionalSplit@(ValidRecords, ErrorRecords)",
				"ConditionalSplit@ValidRecords sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ClientID as integer,",
				"          ClientName as string,",
				"          IndustrySector as string,",
				"          HeadquartersCountry as string,",
				"          RevenueRange as string,",
				"          EmployeeCountRange as string,",
				"          RelationshipType as string,",
				"          AccountManager as string,",
				"          ContractStartDate as date,",
				"          ContractEndDate as date,",
				"          ClientStatus as string,",
				"          LastEngagementDate as date,",
				"          CreatedDate as timestamp,",
				"          ModifiedDate as timestamp",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> TargetClient",
				"ConditionalSplit@ErrorRecords sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          ErrorID as integer,",
				"          PipelineName as string,",
				"          ActivityName as string,",
				"          ErrorMessage as string,",
				"          ErrorTime as timestamp,",
				"          BatchDate as date,",
				"          RecordsProcessed as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> Error"
			]
		}
	}
}